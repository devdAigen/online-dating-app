<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/cardview_light_background"
    android:backgroundTintMode="multiply"
    android:orientation="vertical"
    tools:context="com.example.united.login2.MainActivity"
    tools:layout_editor_absoluteY="81dp">
    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pundi_logoback"
        android:gravity="center"
        android:padding="13dp"
        android:text="Registration Form"
        android:textAllCaps="true"
        android:textColor="@color/cardview_light_background"
        android:textSize="18sp"
        android:textStyle="bold" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/common_google_signin_btn_text_dark_pressed"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">


            <EditText
                android:id="@+id/editText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:drawableLeft="@drawable/prof"
                android:ems="10"
                android:gravity="center_horizontal"
                android:hint="Name"
                android:inputType="text|textCapWords|textPersonName"
                android:textColorHighlight="@color/cardview_light_background"
                tools:layout_editor_absoluteX="75dp"
                tools:layout_editor_absoluteY="75dp" />

            <EditText
                android:id="@+id/editText2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:drawableLeft="@drawable/email"
                android:ems="10"
                android:gravity="center_vertical|center_horizontal|center"
                android:hint="Email Id"
                android:inputType="textEmailAddress"
                android:textColorHighlight="@color/cardview_light_background"
                tools:layout_editor_absoluteX="75dp"
                tools:layout_editor_absoluteY="121dp" />

            <EditText
                android:id="@+id/editText3"
                android:layout_width="match_parent"
                android:layout_height="51dp"
                android:drawableLeft="@drawable/profiles"
                android:ems="10"
                android:gravity="center"
                android:hint="password"
                android:inputType="textPassword"
                tools:layout_editor_absoluteX="75dp"
                tools:layout_editor_absoluteY="176dp" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/common_google_signin_btn_text_light_pressed"
                android:gravity="center"
                android:text="Sex"
                android:textColor="@color/cardview_light_background" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioGroup
                    android:id="@+id/radioGroup3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical|fill_vertical"
                    tools:layout_editor_absoluteX="78dp"
                    tools:layout_editor_absoluteY="223dp">


                    <RadioButton
                        android:id="@+id/male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Male"
                        tools:layout_editor_absoluteX="98dp" />

                    <RadioButton
                        android:id="@+id/female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Female" />

                    <RadioButton
                        android:id="@+id/transgender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Confusion" />


                </RadioGroup>
            </LinearLayout>

            <TextView
                android:id="@+id/textView7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/common_google_signin_btn_text_light_pressed"
                android:gravity="center"
                android:text="Interested"
                android:textColor="@color/cardview_light_background" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorButtonNormal"
                android:orientation="horizontal">


                <RadioGroup
                    android:id="@+id/radioGroup4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/cardview_light_background"
                    android:gravity="center_vertical|fill_vertical"
                    tools:layout_editor_absoluteX="78dp"
                    tools:layout_editor_absoluteY="223dp">


                    <RadioButton
                        android:id="@+id/maleinterest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Male"
                        tools:layout_editor_absoluteX="98dp" />

                    <RadioButton
                        android:id="@+id/femaleinterest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Female" />

                    <RadioButton
                        android:id="@+id/transgenderinterest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="377" />


                </RadioGroup>
            </LinearLayout>

            <Button
                android:id="@+id/button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@android:color/holo_red_dark"
                android:text="Register"
                android:textColor="@color/common_google_signin_btn_text_dark_default"
                tools:layout_editor_absoluteX="136dp"
                tools:layout_editor_absoluteY="295dp" />

            <Button
                android:id="@+id/button3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Login"
                tools:layout_editor_absoluteX="136dp"
                tools:layout_editor_absoluteY="391dp" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
